# =============================================================================
# Buzz Reminders — environment variables
# Copy to .env for local dev. Set the same keys in Vercel (Project → Settings → Environment Variables).
# =============================================================================

# --- Supabase (required for cloud sync + magic-link auth) ---
# 1. Create a project at https://supabase.com/dashboard
# 2. Run supabase/migration.sql in SQL Editor
# 3. Authentication → URL Configuration:
#      Site URL:        https://buzz-reminders.vercel.app
#      Redirect URLs:   https://buzz-reminders.vercel.app/**
#                       buzz-reminders://auth/callback
#                       http://localhost:8081/**
# 4. Project Settings → API → copy URL and anon public key below

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Never commit .env or use the service_role key in the client app.
