{
  "expo": {
    "name": "Buzz Reminders",
    "slug": "buzz-reminders",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "buzz-reminders",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0284C7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.buzzreminders.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0284C7"
      },
      "package": "com.buzzreminders.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png",
      "name": "Buzz Reminders",
      "shortName": "Buzz",
      "description": "Smart reminders with priority alerts",
      "themeColor": "#0284C7",
      "backgroundColor": "#F0F9FF",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-font",
      "@react-native-community/datetimepicker"
    ]
  }
}
